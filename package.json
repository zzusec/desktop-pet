{
  "name": "desktop-pet-lion",
  "version": "1.3.0",
  "description": "桌面小狮子宠物(瑞星小狮子风格)—— Electron 透明置顶窗口,可在整个桌面自由活动",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "make-icon": "electron make-icon.js",
    "dist": "electron-builder --mac dmg"
  },
  "keywords": [
    "electron",
    "desktop-pet",
    "lion",
    "桌面宠物"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.desktoppet.lion",
    "productName": "桌面小狮子",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "package.json"
    ],
    "mac": {
      "identity": null,
      "category": "public.app-category.entertainment",
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        }
      ],
      "icon": "build/icon.png"
    },
    "dmg": {
      "title": "桌面小狮子 ${version}",
      "contents": [
        {
          "x": 150,
          "y": 200,
          "type": "file"
        },
        {
          "x": 400,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
